   "source": [
    "import yfinance as yf\n",
    "import os\n",
    "\n",
    "os.makedirs(\"STPA_PROJ\", exist_ok=True)\n",
    "data = yf.download(\"BZ=F\", start=\"2015-01-01\")\n",
    "data = data[['Open','High','Low','Close','Volume']]\n",
    "data.to_csv(\"STPA_PROJ/brent_data.csv\")\n",
    "\n",
    "print(\"CSV Saved Successfully in STPA_PROJ folder\")"
   ]
  }
